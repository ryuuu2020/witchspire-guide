import type { MetadataRoute } from 'next';

const BASE = 'https://witchspire.gguidehub.com';

// 该文件由 scripts/sync-sitemaps.py 自动生成，新增页面后重新运行脚本即可
const ROUTES = [
    '',
    '/about',
    '/beginners-guide',
    '/boss-attack-patterns',
    '/boss-strategies',
    '/class-builds',
    '/consumables',
    '/coven-build-guide',
    '/coven-tier-list',
    '/crafting',
    '/dungeon-guide',
    '/familiars',
    '/faq',
    '/gear-guide',
    '/guides',
    '/leveling-guide',
    '/news',
    '/potion-brewing-guide',
    '/privacy',
    '/raid-composition',
    '/skill-tree-guide',
    '/spell-guide',
    '/spell-tier-list',
    '/terms',
    '/tier-list',
    '/weapon-guide',
];

export default function sitemap(): MetadataRoute.Sitemap {
  const now = new Date();
  return ROUTES.map((path) => ({
    url: `${BASE}${path}`,
    lastModified: now,
    changeFrequency: path === '' ? ('daily' as const) : ('weekly' as const),
    priority: path === '' ? 1 : ['privacy', 'terms', 'about'].includes(path.slice(1)) ? 0.3 : 0.7,
  }));
}
